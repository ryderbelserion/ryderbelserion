---
import "../assets/css/global.css"

import Header from "../components/header.vue";
import Footer from "../components/footer.vue";

interface properties {
    title: String,
    desc: String
}

const {title, desc} = Astro.props
---

<head>
    <title>Ryder's Tavern | {title}</title>

    <meta name="description" content={desc}>
</head>

<html>
  <body>
    <div class="layout">
        <Header/>

        <main>
            <slot></slot>
        </main>

        <Footer/>
    </div>
  </body>
</html>

<style>
    main {
        width: 100%;
    }

    .layout {
        display: flex;
        flex-direction: column;

        align-self: center;

        height: 100%;
        min-height: 100vh;
        width: 100%;

        max-width: var(--wrap);
    }
</style>